@page "/service-request/{Id:int}"

@using CarService.Core.Entities
@using CarService.Core.Enums
@using CarService.Application.Services

@inject IServiceRequestService Service
@inject NavigationManager Navigation

<h3>Service Request Details</h3>

@if (request == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card p-3">

        <p><b>ID:</b> @request.Id</p>
        <p><b>Description:</b> @request.Description</p>
        <p><b>Base Price:</b> @request.BasePrice</p>
        <p><b>Final Price:</b> @request.FinalPrice</p>
        <p><b>Status:</b> @request.Status</p>
        <p><b>Date:</b> @request.CreatedAt</p>

        <h4>Status: @request.Status</h4>
        @if (request.Status == ServiceStatus.New)
        {
            <button class="btn btn-warning" @onclick="StartRequest">
                Start
            </button>
        }

        @if (request.Status == ServiceStatus.InProgress)
        {
            <button class="btn btn-success" @onclick="CompleteRequest">
                Complete
            </button>
        }
    </div>
}

@code {

    [Parameter]
    public int Id { get; set; }

    ServiceRequest? request;

    protected override async Task OnInitializedAsync()
    {
        request = await Service.GetByIdAsync(Id);
    }

    async Task SetInProgress()
    {
        if (request != null)
        {
            request.Status = ServiceStatus.InProgress;
            await Service.UpdateAsync(request);
            Navigation.NavigateTo("/service-requests", true);
        }
    }

    async Task SetCompleted()
    {
        if (request != null)
        {
            request.Status = ServiceStatus.Completed;
            await Service.UpdateAsync(request);
            Navigation.NavigateTo("/service-requests", true);
        }
    }

    async Task SetCancelled()
    {
        if (request != null)
        {
            request.Status = ServiceStatus.Cancelled;
            await Service.UpdateAsync(request);
            Navigation.NavigateTo("/service-requests", true);
        }
    }

    async Task StartRequest()
    {    
        if (request != null)
        {
            await Service.StartAsync(request.Id);
            request = await Service.GetByIdAsync(request.Id);
        }
    }
    async Task CompleteRequest()
    {   
        if (request != null) 
        {
            await Service.CompleteAsync(request.Id);
            request = await Service.GetByIdAsync(request.Id);
        }
    }    
}